@model SistemaReservas.WebMVC.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="auth-container">
    <div class="auth-card">
        <h2>Iniciar Sesión</h2>

        <div asp-validation-summary="ModelOnly" class="text-danger error-message"></div>

        <form asp-action="Login" method="post">
            <div class="form-group">
                <input asp-for="Email" class="form-control" placeholder="Correo electrónico" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input asp-for="Password" type="password" class="form-control" placeholder="Contraseña" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            
            <button type="submit" class="btn-primary">Ingresar</button>
        </form>

        <p class="auth-link">
            ¿No tienes cuenta? <a asp-action="Register">Regístrate aquí</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
