@{
    ViewData["Title"] = "Inicio";
}

<div class="home-container">
    <div class="hero-section">
        <h1>Reserva tu espacio ideal</h1>
        <p>Encuentra y reserva salas de reuniones, espacios de coworking y zonas de eventos de forma rápida y sencilla.</p>
        <a asp-controller="Zones" asp-action="Index" class="btn-primary">Reservar Ahora</a>
    </div>

    <div class="features-section">
        <div class="feature-card">
            <h3>Fácil de usar</h3>
            <p>Nuestra plataforma intuitiva te permite encontrar y reservar el espacio perfecto en minutos.</p>
        </div>
        <div class="feature-card">
            <h3>Espacios versátiles</h3>
            <p>Desde pequeñas salas de reuniones hasta grandes áreas para eventos, tenemos lo que necesitas.</p>
        </div>
        <div class="feature-card">
            <h3>Gestión eficiente</h3>
            <p>Administra tus reservas de forma rápida y eficiente en la plataforma inteligente.</p>
        </div>
    </div>
</div>
