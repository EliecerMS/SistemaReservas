@model SistemaReservas.WebMVC.Models.ViewModels.AdminIndexViewModel
@{
    ViewData["Title"] = "Panel de Administrador";
}

<div class="admin-container">
    <div class="admin-header">
        <h2>Panel de Administración - Reservas</h2>
        
        <div class="admin-filters">
            <a asp-action="Index" asp-route-statusId="" class="btn @(ViewData["CurrentStatus"] == null ? "btn-primary" : "btn-secondary")">Todas</a>
            <a asp-action="Index" asp-route-statusId="1" class="btn @(ViewData["CurrentStatus"]?.ToString() == "1" ? "btn-primary" : "btn-secondary")">Pendientes</a>
            <a asp-action="Index" asp-route-statusId="2" class="btn @(ViewData["CurrentStatus"]?.ToString() == "2" ? "btn-primary" : "btn-secondary")">Confirmadas</a>
            <a asp-action="Index" asp-route-statusId="3" class="btn @(ViewData["CurrentStatus"]?.ToString() == "3" ? "btn-primary" : "btn-secondary")">Canceladas</a>
        </div>
    </div>

    @if (!Model.Reservations.Any())
    {
        <div class="empty-state">
            <p>No se encontraron reservas con los filtros actuales.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Usuario</th>
                        <th>Zona</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var res in Model.Reservations.OrderByDescending(r => r.Id))
                    {
                        var statusClass = res.StatusName.ToLower() switch
                        {
                            "confirmada" => "status-confirmed",
                            "pendiente" => "status-pending",
                            "cancelada" => "status-cancelled",
                            _ => ""
                        };

                        <tr>
                            <td>@res.Id</td>
                            <td>@(res.UserName ?? $"User {res.UserId}")</td>
                            <td>@res.ZoneName</td>
                            <td>@res.StartTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@res.EndTime.ToString("HH:mm")</td>
                            <td><span class="status-badge @statusClass">@res.StatusName</span></td>
                            <td class="action-buttons">
                                @if (res.StatusName.ToLower() == "pendiente")
                                {
                                    <form asp-action="Confirm" asp-route-id="@res.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-success btn-sm">Confirmar</button>
                                    </form>
                                }
                                @if (res.StatusName.ToLower() != "cancelada")
                                {
                                    <form asp-controller="Reservations" asp-action="Cancel" asp-route-id="@res.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-danger btn-sm" onclick="return confirm('¿Forzar cancelación de esta reserva?');">
                                            Cancelar
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
